{
  "name": "cli-docs",
  "version": "1.0.0",
  "description": "@criticalmanufacturing/cli docs",
  "scripts": {
    "clean": "rm -fr dist && docker rmi cli/docs",
    "build": "earthly +build && earthly +image",
    "rebuild": "npm run clean && npm run build",
    "serve": "docker run --rm --name cli_docs -p 8081:80 cli/docs",

